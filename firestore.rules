rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'avyra303@gmail.com' && request.auth.token.email_verified == true
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Subscriber Validation
    function isValidSubscriber(data) {
      return data.email is string && data.email.size() <= 256 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.createdAt == request.time &&
             (data.get('source', '') is string && data.get('source', '').size() <= 50);
    }

    // --- Subscriptions Collection ---
    match /subscribers/{subscriberId} {
      // 1. Creation - Public can subscribe (no auth required for simple newsletter, 
      // but usually we want to prevent spam. For this prompt's requirement, we'll allow public create).
      // However, to follow the guidelines strictly about not trusting client data:
      allow create: if (
        isValidId(subscriberId) && 
        isValidSubscriber(incoming()) &&
        incoming().keys().hasAll(['email', 'createdAt']) &&
        incoming().keys().size() >= 2 && incoming().keys().size() <= 3
      );

      // 2. Reading - Strictly Admin Only (since it contains PII)
      allow get, list: if isAdmin();

      // 3. Updates/Deletes - Admin Only
      allow update, delete: if isAdmin();
    }
  }
}
